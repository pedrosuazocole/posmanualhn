# ══════════════════════════════════════════════════════════
#  MetricPOS v7.3 — Variables de Entorno (Producción)
#  Copia este archivo como .env y llena los valores
# ══════════════════════════════════════════════════════════

# ── Servidor ────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Seguridad (CAMBIAR OBLIGATORIAMENTE) ────────────────
# Genera una clave aleatoria: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA_DE_64_CHARS

# ── URL pública del servidor (para links de PDF en WhatsApp)
# Railway: se configura automáticamente con RAILWAY_PUBLIC_DOMAIN
# VPS:     tu dominio, ej: https://pos.tuempresa.com
SERVER_URL=https://tu-dominio.com

# ── CORS (dominio que puede hacer requests al API)
# Producción: tu dominio exacto
# Desarrollo: * (cualquiera)
CORS_ORIGIN=https://tu-dominio.com

# ── Base de datos ────────────────────────────────────────
# Railway: usar RAILWAY_VOLUME_MOUNT_PATH (se configura automático con Volume)
# VPS:     ruta absoluta donde guardar la BD
DATA_DIR=/datos/metricpos

# ── Railway (se configuran automáticamente, no tocar) ───
# RAILWAY_PUBLIC_DOMAIN=xxx.up.railway.app
# RAILWAY_VOLUME_MOUNT_PATH=/data
